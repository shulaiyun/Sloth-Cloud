COMPOSE_PROJECT_NAME=slothcloud

SLOTH_WEB_PORT=13000
SLOTH_API_PORT=14000
SLOTH_PAYMENTER_PORT=18080

SLOTH_DB_PASSWORD=replace-with-strong-password
SLOTH_DB_ROOT_PASSWORD=replace-with-even-stronger-password

SLOTH_WEB_PUBLIC_URL=https://app.sloth-cloud.example
SLOTH_API_PUBLIC_URL=https://api.sloth-cloud.example
SLOTH_PAYMENTER_PUBLIC_URL=https://billing.sloth-cloud.example
