APP_NAME="Sloth Cloud Billing Core"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://billing.sloth-cloud.example
APP_TIMEZONE=Asia/Shanghai

APP_LOCALE=zh
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info

DB_CONNECTION=mariadb
DB_HOST=sloth-cloud-db
DB_PORT=3306
DB_DATABASE=slothcloud_paymenter
DB_USERNAME=slothcloud
DB_PASSWORD=replace-with-strong-password

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=sloth-cloud-redis
REDIS_PORT=6379
REDIS_PASSWORD=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
